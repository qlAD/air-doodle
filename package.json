{
  "name": "air-doodle",
  "version": "1.0.0",
  "private": true,
  "description": "AI 手势涂鸦工坊 (Air Doodle Studio) — 基于浏览器摄像头 + MediaPipe + Next.js 的隔空手势涂鸦全栈应用",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev --name init",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.18",
    "@prisma/client": "^6.2.1",
    "html-to-image": "^1.11.13",
    "next": "15.1.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "prisma": "^6.2.1",
    "tailwindcss": "^3.4.17"
  }
}
